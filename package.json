{
  "name": "@gwigz/jsx-inline",
  "version": "1.1.0",
  "description": "Compile JSX templates into optimized inline string literals at build time",
  "keywords": [
    "build-time",
    "compile",
    "html",
    "inline",
    "jsx",
    "minify",
    "tstl",
    "typescript-to-lua"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gwigz/jsx-inline.git"
  },
  "files": [
    "dist"
  ],
  "type": "commonjs",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.cjs --target node --format cjs --packages external && tsc",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "test": "bun test",
    "prepare": "husky"
  },
  "dependencies": {
    "html-minifier-terser": "^7.2.0",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/html-minifier-terser": "^7.0.2",
    "husky": "^9.1.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3"
  }
}
