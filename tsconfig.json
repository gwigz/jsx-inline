{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "jsx": "react"
  },
  "include": ["src"]
}
